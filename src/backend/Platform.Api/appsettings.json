{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Main": ""
  },
  "Cors": {
    "AllowNullOrigin": true,
    "AllowedOrigins": []
  },
  "ServiceAccount": {
    "Enabled": true,
    "RateLimit": {
      "MaxAttempts": 5,
      "LockoutMinutes": 10
    }
  },
  "Jwt": {
    "Issuer": "Platform.Api",
    "Audience": "Platform.Client"
  },
  "Auth": {
    "AutoRecoverSameMachineSession": true
  },
  "KSeF": {
    "Environment": "PRD",
    "Environments": {
      "TE": {
        "ApiBaseUrl": "https://api-test.ksef.mf.gov.pl/v2",
        "ContextNip": "",
        "SubjectIdentifierType": "certificateSubject"
      },
      "TR": {
        "ApiBaseUrl": "https://api-demo.ksef.mf.gov.pl/v2",
        "ContextNip": "",
        "SubjectIdentifierType": "certificateSubject"
      },
      "PRD": {
        "ApiBaseUrl": "https://api.ksef.mf.gov.pl/v2",
        "ContextNip": "",
        "SubjectIdentifierType": "certificateSubject"
      }
    }
  }
}
