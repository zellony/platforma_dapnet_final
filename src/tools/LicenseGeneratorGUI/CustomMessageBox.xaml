<Window x:Class="LicenseGeneratorGUI.CustomMessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Powiadomienie" Height="200" Width="400" 
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    
    <Border Background="#1E2A38" CornerRadius="8" BorderBrush="#3F4E5D" BorderThickness="1">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Tytuł -->
                <RowDefinition Height="*"/>    <!-- Treść -->
                <RowDefinition Height="Auto"/> <!-- Przyciski -->
            </Grid.RowDefinitions>

            <TextBlock x:Name="TxtTitle" FontSize="14" FontWeight="Bold" Foreground="#3F72AF" Margin="0,0,0,15"/>
            
            <TextBlock Grid.Row="1" x:Name="TxtMessage" Foreground="#E0E0E0" TextWrapping="Wrap" FontSize="13" VerticalAlignment="Center"/>

            <StackPanel Grid.Row="2" x:Name="PanelButtons" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <!-- Przyciski będą dodawane dynamicznie w kodzie -->
            </StackPanel>
        </Grid>
    </Border>
</Window>
