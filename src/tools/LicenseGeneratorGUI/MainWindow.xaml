<Window x:Class="LicenseGeneratorGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:System="clr-namespace:System;assembly=mscorlib"
        Title="Generator Licencji DAPNET" Height="850" Width="1100" 
        ResizeMode="CanMinimize" WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent">
    
    <Window.Resources>
        <!-- KOLORYSTYKA -->
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#1E2A38"/>
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#2D3D4D"/> 
        <SolidColorBrush x:Key="TextForegroundBrush" Color="#E0E0E0"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="#9CA3AF"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#3F4E5D"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#3F72AF"/> 
        <SolidColorBrush x:Key="AddButtonBrush" Color="#1E7E34"/>
        <SolidColorBrush x:Key="DeleteButtonBrush" Color="#A93226"/> 
        <SolidColorBrush x:Key="TextBoxBackgroundBrush" Color="#283645"/>
        <SolidColorBrush x:Key="ListBackgroundBrush" Color="#1A242E"/>
        <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="#111921"/>
        <SolidColorBrush x:Key="TabPanelBackgroundBrush" Color="#151E27"/>

        <!-- STYL DLA SCROLLBAR -->
        <Style x:Key="ScrollBarThumb" TargetType="{x:Type Thumb}">
            <Setter Property="OverridesDefaultStyle" Value="true"/>
            <Setter Property="IsTabStop" Value="false"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border x:Name="rectangle" Background="#3F4E5D" CornerRadius="3" Height="{TemplateBinding Height}" Width="{TemplateBinding Width}" Opacity="0.5"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="rectangle" Property="Opacity" Value="1"/>
                                <Setter TargetName="rectangle" Property="Background" Value="#3F72AF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="6"/>
            <Setter Property="Height" Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid x:Name="Bg" Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="true">
                                <Track.Thumb><Thumb Style="{StaticResource ScrollBarThumb}" /></Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Width" Value="Auto"/><Setter Property="Height" Value="6"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type ScrollBar}">
                                <Grid x:Name="Bg" Background="Transparent">
                                    <Track x:Name="PART_Track">
                                        <Track.Thumb><Thumb Style="{StaticResource ScrollBarThumb}" /></Track.Thumb>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextForegroundBrush}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource TextBoxBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextForegroundBrush}"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Height" Value="30"/>
        </Style>

        <Style x:Key="DataGridTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextForegroundBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="10,0"/>
        </Style>

        <!-- STYLE PRZYCISKÓW -->
        <Style x:Key="BaseButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#3F4E5D"/>
            <Setter Property="Foreground" Value="#D0D0D0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#4F5E6D"/>
                                <Setter Property="RenderTransform">
                                    <Setter.Value><ScaleTransform ScaleX="1.02" ScaleY="1.02"/></Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccentButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
        </Style>

        <Style x:Key="AddButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="{StaticResource AddButtonBrush}"/>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#A93226"/>
            <Setter Property="BorderBrush" Value="#A93226"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#A93226"/>
                    <Setter Property="Foreground" Value="#E0E0E0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="HoverIcon" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Opacity" Value="0.7"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="1"/>
                    <Setter Property="RenderTransform">
                        <Setter.Value><ScaleTransform ScaleX="1.1" ScaleY="1.1"/></Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource ListBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextForegroundBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowBackground" Value="#1A242E"/>
            <Setter Property="AlternatingRowBackground" Value="#222E3A"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto"/>
            <Style.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#3F4E5D"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#E0E0E0"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#3F4E5D"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#E0E0E0"/>
            </Style.Resources>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource HeaderBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="{StaticResource TabPanelBackgroundBrush}" Padding="10,0,0,0">
                                <TabPanel IsItemsHost="True" Background="Transparent"/>
                            </Border>
                            <Border Grid.Row="1" Background="Transparent" VerticalAlignment="Stretch">
                                <ContentPresenter ContentSource="SelectedContent" VerticalAlignment="Stretch"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Border" Background="Transparent" Padding="30,15" BorderThickness="0,0,0,4" BorderBrush="Transparent" Margin="0,0,5,0">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="Border" Property="Background" Value="#103F72AF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#15FFFFFF"/>
                                <Setter Property="Foreground" Value="{StaticResource TextForegroundBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DatePicker">
            <Setter Property="CalendarStyle">
                <Setter.Value>
                    <Style TargetType="Calendar">
                        <Setter Property="Background" Value="{StaticResource PanelBackgroundBrush}"/>
                        <Setter Property="Foreground" Value="{StaticResource TextForegroundBrush}"/>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DatePicker">
                        <Border Background="{StaticResource TextBoxBackgroundBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4">
                            <Grid x:Name="PART_Root">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <Button x:Name="PART_Button" Grid.Column="1" Width="30" Height="28" Background="Transparent" BorderThickness="0">
                                    <TextBlock Text="📅" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="16"/>
                                </Button>
                                <DatePickerTextBox x:Name="PART_TextBox" Grid.Column="0" Foreground="White" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" Padding="8,0"/>
                                <Popup x:Name="PART_Popup" AllowsTransparency="True" StaysOpen="False" Placement="Bottom" PlacementTarget="{Binding ElementName=PART_Root}">
                                    <Calendar x:Name="PART_Calendar" Style="{TemplateBinding CalendarStyle}" />
                                </Popup>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Border Background="{StaticResource WindowBackgroundBrush}" CornerRadius="8,8,0,0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Grid Grid.Row="0" Background="{StaticResource PanelBackgroundBrush}" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="45"/><ColumnDefinition Width="45"/></Grid.ColumnDefinitions>
                <TextBlock Text="DAPNET LICENSE GENERATOR" VerticalAlignment="Center" Margin="20,0,0,0" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}"/>
                <Button Grid.Column="1" Content="—" Background="Transparent" Click="MinimizeButton_Click" FontSize="16" Style="{StaticResource BaseButtonStyle}"/>
                <Button Grid.Column="2" Content="✕" Background="Transparent" Click="CloseButton_Click" Foreground="{StaticResource DeleteButtonBrush}" FontSize="16" Style="{StaticResource BaseButtonStyle}"/>
            </Grid>

            <!-- Content -->
            <TabControl Grid.Row="1" VerticalAlignment="Stretch">
                <TabItem Header="KLIENCI">
                    <Grid Margin="20" VerticalAlignment="Stretch">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="350"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        
                        <Grid Grid.Column="0" Margin="0,0,15,0" VerticalAlignment="Stretch">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="LISTA FIRM" FontWeight="Bold" Margin="0,0,0,10" Foreground="{StaticResource TextMutedBrush}"/>
                            <TextBox Grid.Row="1" x:Name="TxtSearchCompany" Margin="0,0,0,10" TextChanged="TxtSearchCompany_TextChanged"/>
                            <Border Grid.Row="2" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4" VerticalAlignment="Stretch">
                                <DataGrid x:Name="DgCompanies" AutoGenerateColumns="False" SelectionChanged="DgCompanies_SelectionChanged" IsReadOnly="True" VerticalAlignment="Stretch" HorizontalScrollBarVisibility="Auto">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="NIP" Binding="{Binding Nip}" Width="110" ElementStyle="{StaticResource DataGridTextStyle}"/>
                                        <DataGridTextColumn Header="Nazwa" Binding="{Binding Name}" Width="300" ElementStyle="{StaticResource DataGridTextStyle}"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Border>
                            <Button Grid.Row="3" Content="+ DODAJ NOWĄ FIRMĘ" Margin="0,15,0,0" Click="BtnShowAddCompany_Click" Style="{StaticResource AccentButtonStyle}" Width="200" HorizontalAlignment="Left"/>
                        </Grid>

                        <Grid Grid.Column="1" x:Name="GridCompanyDetails" Visibility="Collapsed" Margin="10,0,0,0" VerticalAlignment="Stretch">
                            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                            <Border Background="{StaticResource PanelBackgroundBrush}" Padding="20" CornerRadius="6" Margin="0,0,0,15">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock x:Name="TxtCompanyName" FontSize="20" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" TextWrapping="Wrap" MaxWidth="450"/>
                                        <TextBlock x:Name="TxtCompanyNip" FontSize="13" Foreground="{StaticResource TextMutedBrush}"/>
                                        <TextBlock x:Name="TxtCompanyAddress" FontSize="13" Margin="0,8,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <Button Content="EDYTUJ DANE" Margin="0,0,0,10" Click="BtnEditCompany_Click" Width="140" Style="{StaticResource BaseButtonStyle}"/>
                                        <Button Content="USUŃ FIRMĘ" Style="{StaticResource DangerButtonStyle}" VerticalAlignment="Top" Click="BtnDeleteCompany_Click" Width="140"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Grid Grid.Row="1" Margin="0,0,0,15" VerticalAlignment="Stretch">
                                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                                <TextBlock Text="HISTORIA LICENCJI" FontWeight="Bold" Margin="0,0,0,10" Foreground="{StaticResource TextMutedBrush}"/>
                                <Border Grid.Row="1" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4" VerticalAlignment="Stretch">
                                    <DataGrid x:Name="DgLicenses" AutoGenerateColumns="False" IsReadOnly="True" VerticalAlignment="Stretch" HorizontalScrollBarVisibility="Auto">
                                        <DataGrid.Columns>
                                            <DataGridTemplateColumn Header="Akcje" Width="120">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal">
                                                            <Button Content="ℹ️" Click="BtnShowLicenseInfo_Click" Tag="{Binding Id}" Style="{StaticResource HoverIcon}" Margin="0,0,10,0" FontSize="16" Foreground="{StaticResource AccentBrush}"/>
                                                            <Button Content="💾" ToolTip="Eksportuj" Click="BtnExportLicense_Click" Tag="{Binding Id}" Style="{StaticResource HoverIcon}" Margin="0,0,10,0" FontSize="16" Foreground="{StaticResource TextMutedBrush}"/>
                                                            <Button Content="🗑️" Style="{StaticResource DangerButtonStyle}" Click="BtnDeleteLicense_Click" Tag="{Binding Id}" Background="Transparent" BorderThickness="0" FontSize="14"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="300" ElementStyle="{StaticResource DataGridTextStyle}"/>
                                            <DataGridTextColumn Header="Wystawiono" Binding="{Binding IssuedAt, StringFormat=\{0:yyyy-MM-dd HH:mm\}}" Width="150" ElementStyle="{StaticResource DataGridTextStyle}"/>
                                            <DataGridTextColumn Header="Ważna do" Binding="{Binding ExpiresAt, StringFormat=\{0:yyyy-MM-dd\}}" Width="100" ElementStyle="{StaticResource DataGridTextStyle}"/>
                                            <DataGridTextColumn Header="Stan." Binding="{Binding Seats}" Width="65" ElementStyle="{StaticResource DataGridTextStyle}"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Border>
                            </Grid>
                            <Button Grid.Row="2" Style="{StaticResource AccentButtonStyle}" Height="40" Width="280" Click="BtnShowNewLicenseForm_Click" HorizontalAlignment="Left">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="+" FontSize="12" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="#D0D0D0"/>
                                    <TextBlock Text="WYSTAW NOWĄ LICENCJĘ" VerticalAlignment="Center" Foreground="#D0D0D0"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Grid>
                </TabItem>

                <TabItem Header="USTAWIENIA">
                    <Grid Margin="20">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,15,0">
                            <TextBlock Text="BAZA DANYCH" FontWeight="Bold" Margin="0,0,0,15" Foreground="{StaticResource TextMutedBrush}"/>
                            <Border Background="{StaticResource PanelBackgroundBrush}" Padding="20" CornerRadius="6" Margin="0,0,0,20">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Click="BtnExportDatabase_Click" Margin="0,0,5,0" Height="35" Style="{StaticResource BaseButtonStyle}">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="💾" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="EKSPORTUJ" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Grid.Column="1" Click="BtnImportDatabase_Click" Margin="5,0,0,0" Height="35" Style="{StaticResource BaseButtonStyle}">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="📂" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="IMPORTUJ" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                    <TextBlock Text="Uwaga: Import zastąpi dane i zrestartuje program." FontSize="10" Foreground="#9CA3AF" Margin="0,10,0,0" TextWrapping="Wrap" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="KLUCZE RSA" FontWeight="Bold" Margin="0,0,0,15" Foreground="{StaticResource TextMutedBrush}"/>
                            <Border Background="{StaticResource PanelBackgroundBrush}" Padding="20" CornerRadius="6">
                                <StackPanel>
                                    <TextBlock x:Name="TxtKeyStatus" Text="Status..." FontWeight="Bold" Margin="0,0,0,15"/>
                                    <TextBlock Text="PRYWATNY" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                    <Grid Margin="0,5,0,15">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBox x:Name="TxtPrivKeyPreview" IsReadOnly="True" FontSize="10" Opacity="0.6"/>
                                        <Button Grid.Column="1" Content="📂" Click="BtnImportPrivateKey_Click" Style="{StaticResource HoverIcon}" Margin="8,0,0,0" Foreground="{StaticResource AccentBrush}" FontSize="18"/>
                                        <Button Grid.Column="2" Content="🗑️" Click="BtnDeletePrivKey_Click" Style="{StaticResource HoverIcon}" Margin="5,0,0,0" Foreground="{StaticResource DeleteButtonBrush}" FontSize="18"/>
                                    </Grid>
                                    <TextBlock Text="PUBLICZNY" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                    <Grid Margin="0,5,0,20">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBox x:Name="TxtPubKeyPreview" IsReadOnly="True" FontSize="10" Opacity="0.6"/>
                                        <Button Grid.Column="1" Content="📂" Click="BtnImportPublicKey_Click" Style="{StaticResource HoverIcon}" Margin="8,0,0,0" Foreground="{StaticResource AccentBrush}" FontSize="18"/>
                                        <Button Grid.Column="2" Content="🗑️" Click="BtnDeletePubKey_Click" Style="{StaticResource HoverIcon}" Margin="5,0,0,0" Foreground="{StaticResource DeleteButtonBrush}" FontSize="18"/>
                                    </Grid>
                                    <Button Content="GENERUJ NOWĄ PARĘ KLUCZY" Click="BtnKeyGen_Click" Style="{StaticResource DangerButtonStyle}" HorizontalAlignment="Left" Padding="20,8" Width="250"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="MODUŁY" FontWeight="Bold" Margin="0,0,0,15" Foreground="{StaticResource TextMutedBrush}"/>
                            <Border Background="{StaticResource PanelBackgroundBrush}" Padding="20" CornerRadius="6">
                                <StackPanel>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                                        <TextBox x:Name="TxtNewModuleCode" Grid.Column="0" Margin="0,0,5,0"/>
                                        <TextBox x:Name="TxtNewModuleName" Grid.Column="1" Margin="0,0,5,0"/>
                                        <Button Grid.Column="2" Click="BtnAddModule_Click" Style="{StaticResource AddButtonStyle}">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="+" Margin="0,0,8,0" VerticalAlignment="Center" FontSize="12"/>
                                                <TextBlock Text="DODAJ" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4" VerticalAlignment="Stretch">
                                        <DataGrid x:Name="LstModules" AutoGenerateColumns="False" IsReadOnly="True" Height="350" HorizontalScrollBarVisibility="Auto">
                                            <DataGrid.Columns>
                                                <DataGridTemplateColumn Header="Akcje" Width="60">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <Button Content="🗑️" Click="BtnDeleteModule_Click" Tag="{Binding Code}" Style="{StaticResource HoverIcon}" Foreground="{StaticResource DeleteButtonBrush}" FontSize="16"/>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTextColumn Header="Kod" Binding="{Binding Code}" Width="80" ElementStyle="{StaticResource DataGridTextStyle}"/>
                                                <DataGridTextColumn Header="Nazwa" Binding="{Binding Name}" Width="*" ElementStyle="{StaticResource DataGridTextStyle}"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </TabItem>
            </TabControl>

            <!-- ✅ NOWA IKONA WYJŚCIA (STYL DAPNET) -->
            <Button Grid.Row="2" Click="CloseButton_Click" Style="{StaticResource DangerButtonStyle}" HorizontalAlignment="Right" Width="220" Height="45" Margin="0,0,20,20">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🗙" Margin="0,0,10,0" VerticalAlignment="Center" FontSize="18" FontWeight="Bold"/>
                    <TextBlock Text="ZAMKNIJ" VerticalAlignment="Center" FontSize="14"/>
                </StackPanel>
            </Button>

            <!-- MODALE -->
            <Grid x:Name="ModalAddCompany" Grid.RowSpan="3" Background="#CC000000" Visibility="Collapsed">
                <Border Background="{StaticResource WindowBackgroundBrush}" Width="450" VerticalAlignment="Center" Padding="30" CornerRadius="8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock x:Name="TxtModalCompanyTitle" Text="DODAJ NOWĄ FIRMĘ" FontSize="18" FontWeight="Bold" Margin="0,0,0,20" Foreground="{StaticResource AccentBrush}"/>
                        <TextBlock Text="NIP *" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                        <TextBox x:Name="TxtNewNip" Margin="0,5,0,15" MaxLength="12"/>
                        <TextBlock Text="NAZWA FIRMY *" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                        <TextBox x:Name="TxtNewName" Margin="0,5,0,15"/>
                        <TextBlock Text="ADRES" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                        <TextBox x:Name="TxtNewAddress" Margin="0,5,0,15"/>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,10,0">
                                <TextBlock Text="KOD POCZTOWY" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/><TextBox x:Name="TxtNewZip" Margin="0,5,0,15"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="MIASTO" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/><TextBox x:Name="TxtNewCity" Margin="0,5,0,15"/>
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="TELEFON" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                        <TextBox x:Name="TxtNewPhone" Margin="0,5,0,15"/>
                        <TextBlock Text="EMAIL" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                        <TextBox x:Name="TxtNewEmail" Margin="0,5,0,20"/>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="ZAPISZ" Style="{StaticResource AccentButtonStyle}" Click="BtnSaveCompany_Click" Margin="0,0,5,0"/>
                            <Button Grid.Column="1" Content="ANULUJ" Click="BtnCancelModal_Click" Style="{StaticResource BaseButtonStyle}" Margin="5,0,0,0"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid x:Name="ModalNewLicense" Grid.RowSpan="3" Background="#CC000000" Visibility="Collapsed">
                <Border Background="{StaticResource WindowBackgroundBrush}" Width="550" VerticalAlignment="Center" Padding="30" CornerRadius="8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="WYSTAW NOWĄ LICENCJĘ" FontSize="18" FontWeight="Bold" Margin="0,0,0,20" Foreground="{StaticResource AccentBrush}"/>
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="80"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="WAŻNA DO" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/><DatePicker x:Name="DtpNewExpires" Margin="0,5,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="0,0,10,0">
                                <TextBlock Text="AKTUALIZACJE DO" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/><DatePicker x:Name="DtpNewUpdateUntil" Margin="0,5,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="STAN." FontSize="11" Foreground="{StaticResource TextMutedBrush}"/><TextBox x:Name="TxtNewSeats" Text="1" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="WYBIERZ MODUŁY" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                        <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="0,5,0,25" Height="200" Background="{StaticResource ListBackgroundBrush}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel x:Name="StackNewModules" Margin="10,5"/></ScrollViewer>
                        </Border>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="GENERUJ I ZAPISZ" Style="{StaticResource AccentButtonStyle}" Click="BtnConfirmGenerate_Click" Margin="0,0,5,0"/>
                            <Button Grid.Column="1" Content="ANULUJ" Click="BtnCancelModal_Click" Style="{StaticResource BaseButtonStyle}" Margin="5,0,0,0"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid x:Name="ModalLicenseDetails" Grid.RowSpan="3" Background="#CC000000" Visibility="Collapsed">
                <Border Background="{StaticResource WindowBackgroundBrush}" Width="600" VerticalAlignment="Center" Padding="30" CornerRadius="8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="SZCZEGÓŁY LICENCJI" FontSize="18" FontWeight="Bold" Margin="0,0,0,20" Foreground="{StaticResource AccentBrush}"/>
                        <Border Background="{StaticResource PanelBackgroundBrush}" Padding="15" CornerRadius="4" Margin="0,0,0,20">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="ID LICENCJI:" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                    <TextBlock x:Name="TxtDetId" Margin="0,0,0,10" FontSize="11"/>
                                    <TextBlock Text="WYSTAWIONO:" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                    <TextBlock x:Name="TxtDetIssued" Margin="0,0,0,10"/>
                                    <TextBlock Text="WAŻNA DO:" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                    <TextBlock x:Name="TxtDetExpires" Margin="0,0,0,10"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="STANOWISKA:" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                    <TextBlock x:Name="TxtDetSeats" Margin="0,0,0,10"/>
                                    <TextBlock Text="AKTUALIZACJE:" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                    <TextBlock x:Name="TxtDetUpdate" Margin="0,0,0,10"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <TextBlock Text="PRZYPISANE MODUŁY:" FontSize="10" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,5"/>
                        <Border Background="{StaticResource ListBackgroundBrush}" Padding="15" CornerRadius="4" Height="150">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <TextBlock x:Name="TxtDetModules" TextWrapping="Wrap" LineHeight="20"/>
                            </ScrollViewer>
                        </Border>
                        <Button Content="ZAMKNIJ" Margin="0,20,0,0" Click="BtnCloseDetModal_Click" HorizontalAlignment="Right" Width="100" Style="{StaticResource BaseButtonStyle}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
