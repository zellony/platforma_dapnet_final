{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "outDir": "dist-electron/main",
    "rootDir": "main",
    "strict": true,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "types": [ "node", "electron" ],
    "skipLibCheck": true
  },
  "include": [ "main/**/*.ts" ]
}
